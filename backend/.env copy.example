PORT=5000
NODE_ENV=development
MONGO_URI=
JWT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLIENT_URL=http://localhost:5173

# Mailtrap SMTP - local email testing
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_sandbox_username
SMTP_PASS=your_mailtrap_sandbox_password
SMTP_FROM_NAME="Accessible Publishers CRM"
SMTP_FROM_EMAIL=crm@accessiblepublishers.local
SMTP_REPLY_TO=support@accessiblepublishers.local

# Mailtrap SMTP - production email sending
# Use these values in your production environment instead of the sandbox values above.
# SMTP_HOST=live.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_mailtrap_production_username
# SMTP_PASS=your_mailtrap_production_password
# SMTP_FROM_NAME="Accessible Publishers CRM"
# SMTP_FROM_EMAIL=crm@your-verified-domain.com
# SMTP_REPLY_TO=support@your-verified-domain.com
